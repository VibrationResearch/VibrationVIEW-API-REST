# VibrationVIEW REST API - Environment Configuration
# Copy and modify these values as needed for your environment

# API Configuration
API_VERSION=1.0.0
# Not currently required — the API is stateless (no sessions, cookies, or CSRF).
# Pre-configured for future use. Generate a random key with:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=dev-secret-key-change-in-production

# Allow GET on state-changing endpoints (starttest, stoptest, savedata, etc.).
# Set to true for backward compatibility or demonstrations only.
ALLOW_GET_WRITE=false

# CORS Configuration — controls which browser origins may make cross-origin
# requests to the API.  Set to http://127.0.0.1 to block unexpected browser
# access.
CORS_ORIGINS=http://127.0.0.1

# API Key Authentication — requests must include an Authorization: Bearer <key> header.
# Generate a unique key with: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=replace-with-generated-key

# Maximum number of bytes allowed in incoming request data (default: 10 MB).
# Flask rejects requests larger than this before they reach application code.
# MAX_CONTENT_LENGTH=10485760

# Logging Configuration
LOG_LEVEL=INFO
# Absolute path for log files (default: C:\ProgramData\VibrationVIEW\logs).
# VV_LOG_DIR=C:\ProgramData\VibrationVIEW\logs
# Maximum size per log file before rotation (default: 5 MB).
# VV_LOG_MAX_BYTES=5242880
# Number of rotated backup files to keep (default: 5).
# VV_LOG_BACKUP_COUNT=5

# VibrationVIEW Connection Settings
VV_CONNECTION_TIMEOUT=10.0
VV_RETRY_ATTEMPTS=5
VV_MAX_INSTANCES=5

# VibrationVIEW Folder Paths
VIBRATIONVIEW_FOLDER=C:\VibrationVIEW
EXE_NAME=C:\Program Files\VibrationVIEW 2025\VibrationVIEW.exe
# Optional: Override individual folders (defaults to subfolders of VIBRATIONVIEW_FOLDER)
# PROFILE_FOLDER=C:\VibrationVIEW\Profiles
# INPUTCONFIG_FOLDER=C:\VibrationVIEW\InputConfig
# NEW_TEST_DEFAULTS_FOLDER=C:\VibrationVIEW\New Test Defaults
# REPORT_FOLDER=C:\VibrationVIEW\Reports
# DATA_FOLDER=C:\VibrationVIEW\Data
